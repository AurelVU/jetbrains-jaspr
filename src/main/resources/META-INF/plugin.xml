<idea-plugin>
    <id>com.github.nicetyone.jetbrainsjaspr</id>
    <name>Jaspr</name>
    <vendor email="support@example.com" url="https://github.com/nicetyone/jetbrains-jaspr">nicetyone</vendor>

    <description><![CDATA[
    Provides IDE support for the <a href="https://docs.page/schultek/jaspr">Jaspr</a> Dart web framework.

    <h3>Features</h3>
    <ul>
        <li>Run configurations for <code>jaspr serve</code> and <code>jaspr build</code></li>
        <li>File templates for Jaspr components and pages</li>
        <li>Code completion for Jaspr HTML helpers, annotations, and components</li>
        <li>Component scope indicators (Server / Client / Island) via Code Vision</li>
        <li>Component context highlighting with custom color scheme</li>
        <li>Inspections for <code>@client</code> annotation usage</li>
        <li>Intention to wrap selection with Jaspr component</li>
        <li>Configurable Jaspr CLI path in Settings</li>
    </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>Dart</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Project Service -->
        <projectService serviceImplementation="com.github.nicetyone.jetbrainsjaspr.services.JasprProjectService"/>
        <projectService serviceImplementation="com.github.nicetyone.jetbrainsjaspr.services.JasprSettings"/>

        <!-- Settings -->
        <projectConfigurable instance="com.github.nicetyone.jetbrainsjaspr.settings.JasprSettingsConfigurable"
                             id="jaspr.settings"
                             displayName="Jaspr"
                             groupId="language"/>

        <!-- Run Configuration -->
        <configurationType implementation="com.github.nicetyone.jetbrainsjaspr.runconfig.JasprConfigurationType"/>
        <runConfigurationProducer implementation="com.github.nicetyone.jetbrainsjaspr.runconfig.JasprRunConfigurationProducer"/>

        <!-- File Templates -->
        <fileTemplateGroup implementation="com.github.nicetyone.jetbrainsjaspr.templates.JasprFileTemplateGroupFactory"/>

<!-- Completion -->
        <completion.contributor language="Dart"
                                implementationClass="com.github.nicetyone.jetbrainsjaspr.completion.JasprCompletionContributor"/>

        <!-- Code Vision (Scope Indicators) -->
        <codeInsight.codeVisionProvider implementation="com.github.nicetyone.jetbrainsjaspr.codevision.JasprScopeCodeVisionProvider"/>

<!-- Annotator -->
        <annotator language="Dart"
                   implementationClass="com.github.nicetyone.jetbrainsjaspr.annotator.JasprComponentContextAnnotator"/>

        <!-- Color Settings -->
        <colorSettingsPage implementation="com.github.nicetyone.jetbrainsjaspr.annotator.JasprColorSettingsPage"/>

        <!-- Inspections -->
        <localInspection language="Dart"
                         groupName="Jaspr"
                         shortName="JasprClientAnnotationInspection"
                         displayName="@client annotation validation"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.github.nicetyone.jetbrainsjaspr.inspections.JasprClientAnnotationInspection"/>

        <!-- Intentions -->
        <intentionAction>
            <language>Dart</language>
            <className>com.github.nicetyone.jetbrainsjaspr.intentions.WrapWithComponentIntention</className>
            <category>Jaspr</category>
        </intentionAction>
    </extensions>

    <actions>
        <group id="Jaspr.NewGroup" text="Jaspr" popup="true"
               icon="com.github.nicetyone.jetbrainsjaspr.JasprIcons.JASPR">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFile"/>
            <action id="Jaspr.NewComponent"
                    class="com.github.nicetyone.jetbrainsjaspr.actions.NewJasprComponentAction"
                    text="Jaspr Component"
                    description="Create a new Jaspr component"
                    icon="com.github.nicetyone.jetbrainsjaspr.JasprIcons.JASPR"/>
            <action id="Jaspr.NewPage"
                    class="com.github.nicetyone.jetbrainsjaspr.actions.NewJasprPageAction"
                    text="Jaspr Page"
                    description="Create a new Jaspr page with routing"
                    icon="com.github.nicetyone.jetbrainsjaspr.JasprIcons.JASPR"/>
        </group>
    </actions>
</idea-plugin>
